# Copy this to .env and fill in your values

# AWS Cognito
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Cognito Domain (for OAuth/Social Sign-In)
# Format: https://<your-domain>.auth.<region>.amazoncognito.com
VITE_COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com

# OAuth Redirect URLs
VITE_OAUTH_REDIRECT_SIGN_IN=http://localhost:5173/
VITE_OAUTH_REDIRECT_SIGN_OUT=http://localhost:5173/

# API Gateway URL (no trailing slash)
VITE_API_BASE_URL=https://0mx0rw42nd.execute-api.ap-south-1.amazonaws.com/prod
